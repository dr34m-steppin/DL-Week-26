# Core app
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
SECRET_KEY=change-me-in-production

# LLM provider: mock | azure_openai | openai | huggingface
LLM_PROVIDER=mock

# Azure OpenAI (if LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI (if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Hugging Face (if LLM_PROVIDER=huggingface)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Quiz generation enrichment
# Enable pulling short public web summaries per topic to improve question quality.
ENABLE_ONLINE_CONTEXT=1
ONLINE_CONTEXT_MAX_TOPICS=4
ONLINE_CONTEXT_CHARS_PER_TOPIC=550
